# Copie para .env (local) ou configure em Settings > Environment Variables na Vercel

# Login do painel admin (obrigatório — sem isso o /admin.html não deixa entrar)
ADMIN_USER=vperts
ADMIN_PASS=troque-por-uma-senha-forte

# Assinatura obrigatória do cookie de sessão (mínimo recomendado: 32 caracteres aleatórios)
SESSION_SECRET=troque-por-uma-frase-aleatoria-com-mais-de-32-caracteres

# BLOB_READ_WRITE_TOKEN — NÃO precisa criar na mão:
# na Vercel, em Storage > Create Database > Blob e "Connect Project",
# essa variável aparece sozinha no projeto.
